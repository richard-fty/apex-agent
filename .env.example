# Fill in the key for the provider you want to use.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
DEEPSEEK_API_KEY=
MOONSHOT_API_KEY=
VOLCENGINE_API_KEY=

# Embedding / reranking provider: "siliconflow" (default, free) or "huggingface"
EMBEDDING_PROVIDER=siliconflow

# SiliconFlow (recommended — free bge-m3 + bge-reranker, no cold start)
SILICONFLOW_API_KEY=
SILICONFLOW_EMBEDDING_MODEL=BAAI/bge-m3
SILICONFLOW_RERANK_MODEL=BAAI/bge-reranker-v2-m3

# HuggingFace (fallback)
HF_TOKEN=
HF_EMBEDDING_MODEL=intfloat/multilingual-e5-large
HF_RERANK_MODEL=sentence-transformers/msmarco-distilbert-base-tas-b
RAG_RERANK_MODE=auto
RAG_RERANK_MIN_CANDIDATES=8
RAG_RERANK_MAX_CANDIDATES=100

# Optional: improves web search quality for research.
TAVILY_API_KEY=

# Postgres (required by backend/runtime storage)
POSTGRES_USER=apex
POSTGRES_PASSWORD=apex_dev_password
POSTGRES_DB=apex_agent
POSTGRES_PORT=5432
DATABASE_URL=postgresql://apex:apex_dev_password@localhost:5432/apex_agent

# Default model (overrides the default)
# Example: DEFAULT_MODEL=volcengine/your-endpoint-id-here
DEFAULT_MODEL=

# Compressor model (cheap/fast model for summarization - also via Volcengine)
# Example: COMPRESSOR_MODEL=volcengine/your-cheap-model-endpoint
COMPRESSOR_MODEL=
